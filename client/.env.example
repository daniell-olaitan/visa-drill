# Frontend env. The app runs fully without any of these (browser simulator +
# local waitlist). The hyperreal officer is powered by Tavus via the FastAPI
# backend, so the avatar key lives in the backend's .env (../.env), NOT here.

# --- Supabase (optional: waitlist persistence) ----------------------------
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
