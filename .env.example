# Tavus API key from https://platform.tavus.io (API Key in the sidebar).
AVATAR_API_KEY=your-tavus-api-key

# Stock replica used as the interviewer face. List options with `GET /api/replicas`
# (or the Tavus portal) and paste a replica_id here. Defaults to a stock replica.
# AVATAR_REPLICA_ID=r90bbd427f71

# Tavus-hosted LLM that drives the persona. tavus-gpt-oss is the low-latency default.
# AVATAR_LLM_MODEL=tavus-gpt-oss

# Pre-provisioned persona ids. Run `python backend/scripts/provision.py` once, paste
# the three ids here, and startup will skip creating Tavus resources (so ephemeral
# hosts like Render free do not duplicate resources on every cold start).
# PERSONA_B1B2_ID=
# PERSONA_F1_ID=
# PERSONA_H1B_ID=
# PERSONA_J1_ID=
# PERSONA_N400_ID=

# Default interview language (feature #8); full name, e.g. english / spanish.
# DEFAULT_LANGUAGE=english

# Visible interview length in seconds (client countdown; Tavus hard cap is a bit
# higher). Lower this to conserve free-tier minutes. Default 240 (4 minutes).
# INTERVIEW_DURATION_SECONDS=240

# Knowledge base (feature #4): public URL to the USCIS 100 civics questions.
# Defaults to the official USCIS PDF; set empty to disable civics grounding.
# CIVICS_DOCUMENT_URL=https://www.uscis.gov/sites/default/files/document/questions-and-answers/100q.pdf

# Public HTTPS base URL of this server (e.g. an ngrok URL) so Tavus can POST
# webhooks to <base>/api/webhook. Leave unset to rely on verbose polling for reports.
# PUBLIC_BASE_URL=https://your-tunnel.ngrok.app

# Waitlist storage. With these set, the landing's /api/waitlist signups are saved
# to a Supabase `waitlist` table (durable, dedupes on email); without them they
# fall back to a local JSONL file (WAITLIST_FILE, default waitlist.jsonl). Use the
# service_role key (server-side only). See the README "Waitlist" section for the
# one table to create.
# DB_URL=https://your-project.supabase.co
# DB_SERVICE_KEY=your-service-role-key
# WAITLIST_FILE=waitlist.jsonl
# Set a secret to enable the admin view of signups (GET /api/waitlist with the
# X-Admin-Token header). Unset = the endpoint returns 404.
# ADMIN_TOKEN=a-long-random-secret
